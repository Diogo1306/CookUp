# ── CookUp firebase-admin — MODELO de configuração ──
# Copia este ficheiro para ".env" e ajusta os valores.
# O .env NÃO é versionado.

# Porta do servidor de administração (default 4000)
ADMIN_PORT=4000

# Origem do dashboard autorizada a chamar esta API (CORS).
# Deixa vazio em desenvolvimento (aceita qualquer localhost).
# Em produção: ADMIN_CORS_ORIGIN=https://o-teu-dashboard.com
ADMIN_CORS_ORIGIN=

# UID(s) Firebase com permissão de administrador, separados por vírgula.
# Só estes utilizadores podem apagar/alterar contas. Vê o UID na consola
# Firebase (Authentication > Users). Se ficar vazio, qualquer utilizador
# autenticado consegue usar a API (NÃO recomendado).
ADMIN_UIDS=
