<?xml version="1.0" encoding="utf-8"?>
<!-- Chip-pílula dos filtros: muda de aspeto conforme selecionado (usado em radios/checkboxes). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Selecionado: fundo coral claro + borda coral. -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_light" />
            <stroke android:width="1dp" android:color="@color/primary" />
            <corners android:radius="999dp" />
        </shape>
    </item>

    <!-- Por omissão: superfície branca + borda-fio quente. -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_secondary" />
            <stroke android:width="1dp" android:color="@color/stroke_soft" />
            <corners android:radius="999dp" />
        </shape>
    </item>
</selector>
