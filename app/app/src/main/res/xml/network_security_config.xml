<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Permite HTTP em claro para desenvolvimento local.
         Emulador (10.0.2.2) e localhost já cobertos.
         Num dispositivo físico, acrescenta aqui o IP do teu PC
         (o mesmo que definires em COOKUP_BASE_URL no gradle.properties). -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>