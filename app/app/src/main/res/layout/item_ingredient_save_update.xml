<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:paddingVertical="@dimen/margin_very_small"
    android:paddingHorizontal="@dimen/margin_very_small">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="0dp"
        android:layout_weight="2"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/margin_small"
        android:hint="Nome do ingrediente"
        tools:ignore="HardcodedText">

        <AutoCompleteTextView
            android:id="@+id/et_ingredient_name"
            style="@style/input"
            android:imeOptions="actionNext"
            android:inputType="text"
            android:importantForAutofill="no"
            android:focusableInTouchMode="true"
            android:singleLine="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/margin_small"
        android:hint="Quantidade"
        tools:ignore="HardcodedText">

        <EditText
            android:id="@+id/et_ingredient_quantity"
            style="@style/input"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <ImageButton
        android:id="@+id/btn_remove_ingredient"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_trash"
        android:contentDescription="Remover"
        android:background="?android:selectableItemBackgroundBorderless"
        app:tint="@color/red"
        android:padding="@dimen/padding_small"
        tools:ignore="HardcodedText" />
</LinearLayout>
