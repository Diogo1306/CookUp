<?xml version="1.0" encoding="utf-8"?>
<!-- Ecrã de Login (redesign 2f): logo centrado, hierarquia clara, Google destacado -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".ui.activity.LoginActivity">

    <!-- Coluna única e centrada; fillViewport + spacer empurra o rodapé para baixo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/margin_large"
        android:paddingEnd="@dimen/margin_large"
        android:paddingTop="@dimen/margin_large"
        android:paddingBottom="@dimen/margin_medium">

        <!-- Topo: seta de voltar (canto) + bloco de marca centrado -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium">

            <ImageButton
                android:id="@+id/arrow_back"
                android:layout_width="@dimen/icon_size_large"
                android:layout_height="@dimen/icon_size_large"
                android:layout_gravity="start|top"
                android:background="@color/transparent"
                android:contentDescription="@string/arrow_back"
                android:src="@drawable/ic_arrow_left"
                tools:ignore="TouchTargetSizeCheck" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/margin_medium"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!-- Logo CookUp -->
                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/title_login"
                    android:src="@drawable/logo_cookup" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Bem-vindo de volta"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_large"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/poppins_regular"
                    android:text="Inicia sessão para continuares a cozinhar"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_very_small"
                    tools:ignore="HardcodedText" />
            </LinearLayout>
        </FrameLayout>

        <!-- Formulário: e-mail + palavra-passe -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:layout_marginBottom="@dimen/margin_small"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/email"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_small" />

        <EditText
            android:id="@+id/input_email"
            style="@style/input"
            android:autofillHints="emailAddress"
            android:drawableStart="@drawable/ic_email"
            android:drawablePadding="@dimen/padding_small"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:hint="@string/input_login_title_email"
            android:inputType="textEmailAddress"
            android:maxLines="1"
            android:singleLine="true"
            android:textColorHint="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:layout_marginBottom="@dimen/margin_small"
            android:fontFamily="@font/poppins_semibold"
            android:importantForAutofill="no"
            android:text="@string/password"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_small" />

        <!-- Palavra-passe: mantém drawableEnd (o toggle do olho é lido pelo Java) -->
        <EditText
            android:id="@+id/input_password"
            style="@style/input"
            android:autofillHints="password"
            android:clickable="true"
            android:drawableStart="@drawable/ic_lock"
            android:drawableEnd="@drawable/ic_eye_off"
            android:drawablePadding="@dimen/padding_small"
            android:ellipsize="end"
            android:focusable="true"
            android:gravity="center_vertical"
            android:hint="@string/input_login_title_password"
            android:inputType="textPassword"
            android:maxLines="1"
            android:singleLine="true"
            android:textColorHint="@color/text_secondary" />

        <!-- Link "esqueceste-te" alinhado à direita, em coral -->
        <TextView
            android:id="@+id/forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/margin_small"
            android:background="@color/transparent"
            android:fontFamily="@font/poppins_semibold"
            android:importantForAutofill="no"
            android:text="@string/forgot_password"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_very_small" />

        <!-- Botão principal coral -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/login_button"
            style="@style/button_primary"
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/margin_large"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/title_login"
            android:textColor="@color/white" />

        <!-- Separador "ou" -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/stroke_soft" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginEnd="@dimen/margin_small"
                android:fontFamily="@font/poppins_regular"
                android:text="ou"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_very_small"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/stroke_soft" />
        </LinearLayout>

        <!-- Botão Google destacado (contorno) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/google_Button"
            style="@style/button_secundary"
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/margin_medium"
            android:drawableStart="@drawable/ic_google"
            android:drawablePadding="@dimen/padding_small"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:text="@string/google"
            android:textAllCaps="false"
            android:textColor="@color/text_primary" />

        <!-- Ir para o registo -->
        <TextView
            android:id="@+id/logintosingup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:text="@string/logintosingup"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_small" />

        <!-- Empurra o rodapé para o fundo do ecrã -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="@dimen/margin_large" />

        <!-- Rodapé: termos e privacidade -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:text="@string/privacy_policy"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_very_small" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
