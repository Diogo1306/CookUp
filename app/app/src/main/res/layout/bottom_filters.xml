<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom sheet de Filtros (redesign): opções em chips-pílula + contagem no botão. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottomSheetContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bg_bottom_sheet"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="@dimen/padding_large">

        <!-- Puxador -->
        <View
            android:layout_width="44dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_handle" />

        <!-- Cabeçalho: título + "Limpar tudo" (buttonCancel repurposed) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Filtros"
                android:textSize="@dimen/text_large_m"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/buttonCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:stateListAnimator="@null"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="@dimen/padding_very_small"
                android:text="Limpar tudo"
                android:textAllCaps="false"
                android:textSize="@dimen/text_very_small"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/primary"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- Ordenar por -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:layout_marginBottom="@dimen/margin_small"
            android:text="@string/OrderBy"
            android:textSize="@dimen/text_very_small"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_primary" />

        <!-- Chips de ordenação (scroll horizontal para nunca cortar) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <RadioGroup
                android:id="@+id/radioGroupOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radioRecommended"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="@dimen/margin_small"
                    android:button="@null"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_filters_chip"
                    android:includeFontPadding="false"
                    android:textSize="@dimen/text_very_small"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_primary"
                    android:text="@string/recommend" />

                <RadioButton
                    android:id="@+id/radioPopular"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="@dimen/margin_small"
                    android:button="@null"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_filters_chip"
                    android:includeFontPadding="false"
                    android:textSize="@dimen/text_very_small"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_primary"
                    android:text="@string/Popular" />

                <RadioButton
                    android:id="@+id/radioRecent"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="@dimen/margin_small"
                    android:button="@null"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_filters_chip"
                    android:includeFontPadding="false"
                    android:textSize="@dimen/text_very_small"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_primary"
                    android:text="@string/Recent" />

                <RadioButton
                    android:id="@+id/radioWeek"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:button="@null"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_filters_chip"
                    android:includeFontPadding="false"
                    android:textSize="@dimen/text_very_small"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_primary"
                    android:text="@string/Weekly" />
            </RadioGroup>
        </HorizontalScrollView>

        <!-- Dificuldade -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:layout_marginBottom="@dimen/margin_small"
            android:text="@string/Difficulty"
            android:textSize="@dimen/text_very_small"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start|center_vertical">

            <CheckBox
                android:id="@+id/checkEasy"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="@dimen/margin_small"
                android:button="@null"
                android:gravity="center"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium"
                android:background="@drawable/bg_filters_chip"
                android:includeFontPadding="false"
                android:textSize="@dimen/text_very_small"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"
                android:text="@string/Easy" />

            <CheckBox
                android:id="@+id/checkMedium"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="@dimen/margin_small"
                android:button="@null"
                android:gravity="center"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium"
                android:background="@drawable/bg_filters_chip"
                android:includeFontPadding="false"
                android:textSize="@dimen/text_very_small"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"
                android:text="@string/Medium" />

            <CheckBox
                android:id="@+id/checkHard"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:button="@null"
                android:gravity="center"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium"
                android:background="@drawable/bg_filters_chip"
                android:includeFontPadding="false"
                android:textSize="@dimen/text_very_small"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"
                android:text="@string/Hard" />
        </LinearLayout>

        <!-- Tempo máximo: label + badge do valor, slider por baixo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin_medium"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/MaximumTimeM"
                android:textSize="@dimen/text_very_small"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/textMaxTimeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_filters_value_pill"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textSize="@dimen/text_very_small"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"
                android:text="0 min"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekMaxTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:max="120"
            android:progressTint="@color/primary"
            android:progressBackgroundTint="@color/stroke_soft"
            android:thumbTint="@color/primary" />

        <!-- Ingredientes máximos: label + badge do valor, slider por baixo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin_medium"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/MaximumIngredients"
                android:textSize="@dimen/text_very_small"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/textMaxIngredientsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_filters_value_pill"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textSize="@dimen/text_very_small"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_primary"
                android:text="0"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekMaxIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:max="20"
            android:progressTint="@color/primary"
            android:progressBackgroundTint="@color/stroke_soft"
            android:thumbTint="@color/primary" />

        <!-- Botão principal: mostra a contagem de resultados (o número é definido no Java) -->
        <Button
            android:id="@+id/buttonApply"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="@dimen/margin_large"
            style="@style/button_primary"
            android:text="Ver receitas"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_semibold"
            tools:ignore="HardcodedText" />
    </LinearLayout>
</ScrollView>
