<?xml version="1.0" encoding="utf-8"?>
<!-- Criar / Editar Receita — redesign (creme quente + coral).
     Secções claras, passo numerado, steppers de doses/tempo e dificuldade segmentada. -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="@dimen/margin_large"
    android:imeOptions="actionDone"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <!-- Cabeçalho: voltar + título -->
        <LinearLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/background"
            android:paddingTop="@dimen/padding_small"
            android:paddingBottom="@dimen/padding_medium">

            <ImageButton
                android:id="@+id/arrow_back"
                android:layout_width="@dimen/icon_size_medium"
                android:layout_height="@dimen/icon_size_medium"
                android:background="@android:color/transparent"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_arrow_left" />

            <TextView
                android:id="@+id/txt_title_saveOrUpdate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_weight="1"
                android:text="@string/create_recipe"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_large"
                android:fontFamily="@font/poppins_semibold"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Galeria de fotos: capa + miniaturas -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/bg_card_soft"
            android:padding="@dimen/padding_small"
            android:layout_marginBottom="@dimen/margin_small">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_gallery"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                tools:listitem="@layout/item_gallery_image" />

            <ImageView
                android:id="@+id/img_gallery_placeholder"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_image"
                android:scaleType="centerInside"
                app:tint="@color/text_secondary"
                android:contentDescription="@string/RecipeImages"
                android:visibility="visible" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_gallery_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/gallery_hint"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_very_small"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginBottom="@dimen/margin_small" />

        <!-- Botão adicionar fotos (secundário coral) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_add_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/button_secundary"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:textColor="@color/primary"
            android:background="@drawable/button_secundary"
            android:text="@string/AddImage"
            android:textSize="@dimen/text_medium"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="@dimen/margin_large" />

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recipe_title"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="@dimen/margin_very_small" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionDone"
            android:singleLine="true"
            app:boxBackgroundColor="@color/background_secondary"
            app:boxStrokeColor="@color/stroke_soft"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="@color/text_secondary"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:hint="@string/enter_recipe_name" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Categorias -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/categories"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="@dimen/margin_very_small" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:singleSelection="false"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp" />

        <!-- Descrição -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recipe_description_label"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="@dimen/margin_very_small" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionDone"
            app:boxBackgroundColor="@color/background_secondary"
            app:boxStrokeColor="@color/stroke_soft"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="@color/text_secondary"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:gravity="top"
                android:hint="@string/describe_recipe"
                android:minLines="2"
                android:maxLines="6" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Doses e Tempo com stepper (− valor +) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <!-- Doses -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="@dimen/margin_small">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/servings"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="@dimen/margin_very_small" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <TextView
                        android:id="@+id/btn_servings_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_btn"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@string/servings"
                        tools:ignore="HardcodedText" />

                    <EditText
                        android:id="@+id/et_servings"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="center"
                        android:inputType="number"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_medium"
                        android:fontFamily="@font/poppins_semibold"
                        android:hint="@string/servings"
                        android:textColorHint="@color/text_secondary"
                        android:maxLength="3"
                        android:importantForAutofill="no" />

                    <TextView
                        android:id="@+id/btn_servings_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_btn"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@string/servings"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </LinearLayout>

            <!-- Tempo (min) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/margin_small">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/preparation_time"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="@dimen/margin_very_small" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <TextView
                        android:id="@+id/btn_time_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_btn"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@string/preparation_time"
                        tools:ignore="HardcodedText" />

                    <EditText
                        android:id="@+id/et_preparation_time"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="center"
                        android:inputType="number"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_medium"
                        android:fontFamily="@font/poppins_semibold"
                        android:hint="@string/preparation_time"
                        android:textColorHint="@color/text_secondary"
                        android:maxLength="4"
                        android:importantForAutofill="no" />

                    <TextView
                        android:id="@+id/btn_time_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_btn"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@string/preparation_time"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Dificuldade: seletor segmentado (Fácil / Médio / Difícil).
             Os segmentos são a UI visível; o RadioGroup abaixo (oculto) mantém
             a ligação existente com o Java. Início: Fácil selecionado. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/difficulty"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="@dimen/margin_very_small" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_segment_track"
            android:padding="3dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/btn_diff_easy"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="38dp"
                android:gravity="center"
                android:background="@drawable/bg_segment_selected"
                android:text="@string/easy"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_semibold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_diff_medium"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="38dp"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:text="@string/medium"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_diff_hard"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="38dp"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:text="@string/hard"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- RadioGroup oculto: fonte de verdade da dificuldade lida pelo Java. -->
        <RadioGroup
            android:id="@+id/rg_difficulty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">
            <RadioButton
                android:id="@+id/rb_easy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/easy" />
            <RadioButton
                android:id="@+id/rb_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/medium" />
            <RadioButton
                android:id="@+id/rb_hard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hard" />
        </RadioGroup>

        <!-- Ingredientes: lista dentro de cartão + botão adicionar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ingredients"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="@dimen/margin_very_small" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_soft"
            android:padding="@dimen/padding_small"
            android:layout_marginBottom="@dimen/margin_small">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_ingredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="10dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_ingredient_save_update" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_add_ingredient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/button_secundary"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:textColor="@color/primary"
            android:background="@drawable/button_secundary"
            android:text="@string/AddIngredients"
            android:textSize="@dimen/text_medium"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="@dimen/margin_large" />

        <!-- Instruções: passo numerado (círculo coral) + campo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/instructions"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="@dimen/margin_very_small" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/margin_large">

            <TextView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_step_number"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginTop="11dp"
                android:layout_marginEnd="@dimen/margin_small"
                tools:ignore="HardcodedText" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                app:boxBackgroundColor="@color/background_secondary"
                app:boxStrokeColor="@color/stroke_soft"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="@color/text_secondary"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_instructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="top"
                    android:hint="@string/explain_steps"
                    android:minLines="3"
                    android:maxLines="10" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_saving"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/margin_medium"
            android:indeterminate="true" />

        <!-- Publicar receita (primário coral) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/button_primary"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:textColor="@color/white"
            android:background="@drawable/button_primary"
            android:text="@string/save_recipe"
            android:textSize="@dimen/text_medium"
            android:layout_marginTop="@dimen/margin_small"
            android:layout_marginBottom="@dimen/margin_large" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
