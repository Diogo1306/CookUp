<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutAnimation="@anim/layout_animation_fade_slide_up"
    android:layout_marginTop="@dimen/margin_large"
    android:background="@color/background"
    tools:context=".ui.fragment.ChangePasswordFragment">

    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/padding_medium"
        android:layout_marginStart="@dimen/margin_small"
        android:layout_marginEnd="@dimen/margin_small"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/arrow_back"
            android:layout_width="@dimen/icon_size_medium"
            android:layout_height="@dimen/icon_size_medium"
            android:background="@color/transparent"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/text_primary"
            tools:ignore="TouchTargetSizeCheck" />

        <TextView
            android:id="@+id/title_change_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_medium"
            android:text="@string/title_change_password"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_large_m"
            android:fontFamily="@font/poppins_semibold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/padding_large"
        app:layout_constraintTop_toBottomOf="@id/header_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/padding_small"
            android:paddingStart="@dimen/padding_medium"
            android:paddingEnd="@dimen/padding_medium">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_very_small"
                android:layout_marginBottom="@dimen/margin_small"
                android:text="@string/password"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_very_small"
                android:fontFamily="@font/poppins_semibold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/background_secondary"
                app:cardCornerRadius="@dimen/border_radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@color/stroke_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <!-- Current password -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_very_small"
                            android:layout_marginBottom="@dimen/margin_small"
                            android:text="@string/current_password"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_very_small"
                            android:fontFamily="@font/poppins_semibold" />

                        <EditText
                            android:id="@+id/currentPasswordEditText"
                            style="@style/input"
                            android:autofillHints="password"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawableEnd="@drawable/ic_eye_off"
                            android:drawablePadding="@dimen/padding_small"
                            android:ellipsize="end"
                            android:gravity="center_vertical"
                            android:hint="@string/current_password"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:focusable="true"
                            android:clickable="true" />
                    </LinearLayout>

                    <!-- New password -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/margin_medium">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_very_small"
                            android:layout_marginBottom="@dimen/margin_small"
                            android:text="@string/new_password"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_very_small"
                            android:fontFamily="@font/poppins_semibold" />

                        <EditText
                            android:id="@+id/newPasswordEditText"
                            style="@style/input"
                            android:autofillHints="password"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawableEnd="@drawable/ic_eye_off"
                            android:drawablePadding="@dimen/padding_small"
                            android:ellipsize="end"
                            android:gravity="center_vertical"
                            android:hint="@string/new_password"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:focusable="true"
                            android:clickable="true" />
                    </LinearLayout>

                    <!-- Confirm new password -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/margin_medium">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_very_small"
                            android:layout_marginBottom="@dimen/margin_small"
                            android:text="@string/confirm_password"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_very_small"
                            android:fontFamily="@font/poppins_semibold" />

                        <EditText
                            android:id="@+id/confirmNewPasswordEditText"
                            style="@style/input"
                            android:autofillHints="password"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawableEnd="@drawable/ic_eye_off"
                            android:drawablePadding="@dimen/padding_small"
                            android:ellipsize="end"
                            android:gravity="center_vertical"
                            android:hint="@string/confirm_password"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:focusable="true"
                            android:clickable="true" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/changePasswordButton"
                style="@style/button_primary"
                android:layout_width="match_parent"
                android:layout_marginTop="@dimen/margin_large"
                android:text="@string/button_continue" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
