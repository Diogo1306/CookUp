# ── CookUp Dashboard — MODELO de configuração ──
# Copia este ficheiro para ".env" e preenche os valores.
# O .env NÃO é versionado (está no .gitignore).

# API principal (PHP) — o teu IP + caminho da pasta api/
VITE_API_URL=http://O_TEU_IP/caminho/para/api/public/api.php

# Backend de administração (firebase-admin) — normalmente localhost
VITE_ADMIN_URL=http://localhost:4000

# Configuração Firebase (web) — consola Firebase > Definições do projeto
VITE_FIREBASE_API_KEY=A_TUA_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=o-teu-projeto.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://o-teu-projeto-default-rtdb.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=o-teu-projeto
VITE_FIREBASE_STORAGE_BUCKET=o-teu-projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
